{
  "name": "creamdesign",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "React Component Library",
  "scripts": {
    "storybook": "cd packages/docs-site && pnpm dev",
    "build-storybook": "cd packages/docs-site && pnpm build",
    "build:all": "pnpm -r build",
    "build:components": "cd packages/components && pnpm build",
    "prepare": "husky install",
    "lint": "eslint packages --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint packages --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,scss,css,md}\"",
    "commit": "git-cz",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.test.{ts,tsx}",
          "**/*.stories.{ts,tsx}"
        ],
        "rules": {
          "testing-library/render-result-naming-convention": "off",
          "testing-library/prefer-screen-queries": "off",
          "testing-library/no-node-access": "off",
          "testing-library/no-container": "off",
          "testing-library/no-render-in-setup": "off",
          "testing-library/no-wait-for-multiple-assertions": "off",
          "testing-library/prefer-presence-queries": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.stories.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/stories/**",
      "!src/App.tsx",
      "!src/index.tsx",
      "!src/component/Upload/hooks/useLargeFileUpload/**",
      "!src/component/Table/TableVirtualBody.tsx",
      "!src/component/Table/hooks/useVirtualScroll.ts",
      "!src/component/Table/PerformanceTest.stories.tsx"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 65,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4",
    "prop-types": "^15.8.1",
    "rollup": "^4.28.0",
    "rollup-plugin-exclude-dependencies-from-bundle": "^1.1.24",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.94.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{scss,css}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
